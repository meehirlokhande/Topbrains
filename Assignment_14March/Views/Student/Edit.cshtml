@model Assignment_14March.Models.Student
@{
    ViewData["Title"] = "Edit Student";
}
<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="StudentId" />
    <div asp-validation-summary="All" class="text-danger"></div>
    <div class="mb-2">
        <label asp-for="StudentName"></label>
        <input asp-for="StudentName" class="form-control" />
    </div>
    <div class="mb-2">
        <label asp-for="Email"></label>
        <input asp-for="Email" class="form-control" />
    </div>
    <div class="mb-2">
        <label asp-for="PhoneNumber"></label>
        <input asp-for="PhoneNumber" class="form-control" />
    </div>
    <div class="mb-2">
        <label asp-for="Address"></label>
        <input asp-for="Address" class="form-control" />
    </div>
    <div class="mb-2">
        <label asp-for="DepartmentId"></label>
        <select asp-for="DepartmentId" asp-items="ViewBag.Departments" class="form-select"></select>
    </div>
    <div class="mb-2">
        <label asp-for="CourseId"></label>
        <select asp-for="CourseId" asp-items="ViewBag.Courses" class="form-select"></select>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index">Cancel</a>
</form>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}