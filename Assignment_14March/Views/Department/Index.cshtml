@model IEnumerable<Assignment_14March.Models.Department>
@{
    ViewData["Title"] = "Departments";
}
@if (TempData["Success"] != null)
{
    <p class="text-success">@TempData["Success"]</p>
}
<p><a asp-action="Create">Add Department</a></p>
<table class="table table-bordered">
    <thead><tr><th>Name</th><th>Description</th><th></th></tr></thead>
    <tbody>
        @foreach (var d in Model)
        {
            <tr>
                <td>@d.DepartmentName</td>
                <td>@d.Description</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@d.DepartmentId">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@d.DepartmentId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>