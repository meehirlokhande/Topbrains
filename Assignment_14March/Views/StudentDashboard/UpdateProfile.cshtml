@model Assignment_14March.ViewModels.StudentUpdateProfileViewModel
@{
    ViewData["Title"] = "Update Profile";
}
@if (TempData["Success"] != null)
{
    <p class="text-success">@TempData["Success"]</p>
}
<form asp-action="UpdateProfile" method="post">
    <input type="hidden" asp-for="StudentId" />
    <p><strong>Name:</strong> @Model.StudentName</p>
    <p><strong>Email:</strong> @Model.Email</p>
    <p><strong>Department:</strong> @Model.DepartmentName</p>
    <p><strong>Course:</strong> @Model.CourseName</p>
    <div class="mb-2">
        <label asp-for="PhoneNumber"></label>
        <input asp-for="PhoneNumber" class="form-control" />
    </div>
    <div class="mb-2">
        <label asp-for="Address"></label>
        <input asp-for="Address" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Profile">Cancel</a>
</form>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}