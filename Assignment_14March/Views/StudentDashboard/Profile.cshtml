@model Assignment_14March.ViewModels.StudentProfileViewModel
@{
    ViewData["Title"] = "Profile";
}
<h2>Profile</h2>
<table class="table table-bordered">
    <tr><th>Name</th><td>@Model.StudentName</td></tr>
    <tr><th>Email</th><td>@Model.Email</td></tr>
    <tr><th>Phone</th><td>@Model.PhoneNumber</td></tr>
    <tr><th>Address</th><td>@Model.Address</td></tr>
    <tr><th>Department</th><td>@Model.DepartmentName</td></tr>
    <tr><th>Course</th><td>@Model.CourseName</td></tr>
</table>
<a asp-action="UpdateProfile">Update Profile</a>