@model Assignment_14March.Models.Course
@{
    ViewData["Title"] = "Add Course";
}
<form asp-action="Create" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>
    <div class="mb-2">
        <label asp-for="CourseName"></label>
        <input asp-for="CourseName" class="form-control" />
    </div>
    <div class="mb-2">
        <label asp-for="Duration"></label>
        <input asp-for="Duration" class="form-control" />
    </div>
    <div class="mb-2">
        <label asp-for="Fees"></label>
        <input asp-for="Fees" class="form-control" type="number" step="0.01" />
    </div>
    <div class="mb-2">
        <label asp-for="DepartmentId"></label>
        <select asp-for="DepartmentId" asp-items="@(ViewBag.Departments as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)" class="form-select"></select>
        <span asp-validation-for="DepartmentId" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index">Cancel</a>
</form>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}